# Files routed through the secrets filter.
# clean: real value -> placeholder when staging/committing
# smudge: placeholder -> real value when checking out
#
# To add a new protected file, append a line like:
#   path/to/file filter=secrets
#
# To add a new secret value, append a line to .secrets.local:
#   SECRET_NAME=real_value_here

backed/AI_Study_Notes/src/main/java/org/example/ai_study_notes/aiservice/client/AIModelConfig.java filter=secrets
backed/**/application*.yml filter=secrets
backed/**/application*.yaml filter=secrets
backed/**/application*.properties filter=secrets
