# Copy this file to .secrets.local and fill in real values.
# .secrets.local is gitignored and stays on your machine only.
#
# Format: ONE secret per line, KEY=VALUE, no quotes, no spaces around '='.
# Lines starting with '#' and blank lines are ignored.
#
# Placeholder in committed code looks like: <your KEY_NAME>
# e.g. if you add ARK_API_KEY=ark-xxx here, then
#   - working tree shows: "ark-xxx"
#   - committed file shows: "<your ARK_API_KEY>"

ARK_API_KEY=<paste your real ARK key here>
# DB_PASSWORD=
# WECHAT_APP_SECRET=
# OPENAI_API_KEY=
